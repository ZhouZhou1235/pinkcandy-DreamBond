config_version=5

[application]

config/name="Dream Bond"
config/description="梦镜纽带
周周制作的关于群友设定之视觉小说游戏
"
config/version="0.0.0"
run/main_scene="uid://djeb0cuoeaeet"
config/use_custom_user_dir=true
config/custom_user_dir_name="pinkcandy-DreamBond"
config/features=PackedStringArray("4.6", "GL Compatibility")
boot_splash/show_image=false
config/icon="res://assets/icon.svg"

[autoload]

GLBOAL="*uid://grfs687pd08h"
Dialogic="*uid://ds2q0uclmolvu"

[dialogic]

directories/dch_directory={
"Player": "res://dialog-system/characters/Player.dch"
}
directories/dtl_directory={
"timeline1-start": "res://dialog-system/timelines/timeline1-start.dtl"
}
layout/style_directory={}
glossary/default_case_sensitive=true
variables={
"player_name": "",
"player_sex": ""
}

[display]

window/size/viewport_width=680
window/size/viewport_height=480
window/stretch/mode="viewport"
window/stretch/scale_mode="integer"

[editor_plugins]

enabled=PackedStringArray("res://addons/dialogic/plugin.cfg")

